{
  "name": "lumen",
  "displayName": "Lumen",
  "description": "Explains AI-generated code changes in a side panel",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lumen",
          "title": "Lumen",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "lumen": [
        {
          "type": "webview",
          "id": "lumen.panel",
          "name": "Lumen",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "lumen.explainSelection",
        "title": "Lumen: Explain Selection"
      },
      {
        "command": "lumen.explainLastDiff",
        "title": "Lumen: Explain Last Diff"
      },
      {
        "command": "lumen.toggleLevel",
        "title": "Lumen: Toggle Understanding Level"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "lumen.explainSelection",
          "when": "editorHasSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lumen.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "lumen.explainLastDiff",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      }
    ],
    "configuration": {
      "title": "Lumen",
      "properties": {
        "lumen.anthropicApiKey": {
          "type": "string",
          "description": "Anthropic API key"
        },
        "lumen.model": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Model to use"
        },
        "lumen.debounceMs": {
          "type": "number",
          "default": 3000,
          "description": "Debounce delay in ms"
        },
        "lumen.defaultLevel": {
          "type": "string",
          "enum": [
            "architecture",
            "developer",
            "syntax"
          ],
          "default": "developer",
          "description": "Default understanding level"
        },
        "lumen.ignorePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "node_modules",
            ".git",
            "dist",
            "*.min.js",
            "*.min.css",
            "*.map",
            "package-lock.json",
            "yarn.lock",
            "pnpm-lock.yaml"
          ],
          "description": "Glob patterns for files Lumen should ignore (supports *, **, ?)"
        },
        "lumen.maxTokens": {
          "type": "number",
          "default": 1024,
          "minimum": 256,
          "maximum": 4096,
          "description": "Maximum tokens for LLM responses"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js --production",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --preserveWatchOutput",
    "package": "node esbuild.js --production",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25",
    "npm-run-all2": "^6",
    "typescript": "^5.4",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "diff": "^8.0.3",
    "marked": "^15.0.0"
  }
}
