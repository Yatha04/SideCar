{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "npm run compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "watch:esbuild",
      "type": "shell",
      "command": "node esbuild.js --watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^> (.+):(\\d+):(\\d+): (error|warning): (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      }
    },
    {
      "label": "watch:tsc",
      "type": "shell",
      "command": "tsc --noEmit --watch --preserveWatchOutput",
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "watch",
      "dependsOn": ["watch:esbuild", "watch:tsc"]
    }
  ]
}
